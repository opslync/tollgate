{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "id": null,
  "uid": "tollgate",
  "title": "Tollgate",
  "description": "Per-agent spend, throughput, and budget state for AI agent traffic proxied through Tollgate.",
  "tags": ["tollgate"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Spend by agent (24h)",
      "description": "sum by (agent) (increase(tollgate_cost_usd_total[24h]))",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (agent) (increase(tollgate_cost_usd_total[24h]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "min": 0 },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests/sec by agent",
      "description": "sum by (agent) (rate(tollgate_requests_total[1m]))",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (agent) (rate(tollgate_requests_total[1m]))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tokens in/out by agent",
      "description": "sum by (agent, direction) (rate(tollgate_tokens_total[5m]))",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (agent, direction) (rate(tollgate_tokens_total[5m]))",
          "legendFormat": "{{agent}} {{direction}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Budget consumed %",
      "description": "tollgate_budget_consumed_ratio * 100",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "tollgate_budget_consumed_ratio * 100",
          "legendFormat": "{{dimension}}:{{target}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Budget state",
      "description": "tollgate_budget_state (0=ok, 1=alert, 2=throttled, 3=blocked)",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "tollgate_budget_state",
          "legendFormat": "{{dimension}}:{{target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OK", "color": "green" },
                "1": { "text": "Alert", "color": "yellow" },
                "2": { "text": "Throttled", "color": "orange" },
                "3": { "text": "Blocked", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p95 latency by provider/model",
      "description": "histogram_quantile(0.95, sum by (le, provider, model) (rate(tollgate_request_duration_seconds_bucket[5m])))",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, provider, model) (rate(tollgate_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} {{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Denied requests by reason",
      "description": "sum by (reason) (rate(tollgate_requests_denied_total[5m]))",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(tollgate_requests_denied_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    }
  ]
}
